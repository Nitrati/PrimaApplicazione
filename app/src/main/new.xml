<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools" android:id="@+id/main"
    android:layout_width="match_parent" android:layout_height="match_parent"
    tools:context=".MainActivity">

    <ImageView android:id="@+id/ImgFotoScuola" android:layout_width="263dp"
        android:layout_height="184dp" android:layout_marginTop="48dp"
        app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/images" /> <!-- Changed tools:srcCompat to app:srcCompat -->

    <EditText android:id="@+id/txtMessaggio" android:layout_width="252dp"
        android:layout_height="71dp" android:layout_marginTop="32dp" android:ems="10"
        android:inputType="text" android:hint="Scrivi un testo"
        app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ImgFotoScuola" /> <!-- Changed android:text to android:hint -->

    <Button android:id="@+id/btnMostra" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:layout_marginBottom="72dp"
        android:text="Mostra" app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" /> <!-- Added Start constraint to center it -->

</androidx.constraintlayout.widget.ConstraintLayout>