<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">
<!--
Button:
    al click eseguirà un'azione in Java.
    Importante per Java:
    android:id="@+id/btnMostra"
    Questo id verrà usato in Java con:
    findViewBuild(R.id.btnMostra)

    In Java si collegherà anche l'evento...
-->


    <Button
        android:id="@+id/btnMostra"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="228dp"
        android:text="Button"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:layout_editor_absoluteX="160dp" />
    <!--
    ImageView:
    -->
    <ImageView
        android:id="@+id/ImgFotoScuola"
        android:layout_width="263dp"
        android:layout_height="184dp"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toTopOf="parent"
        tools:layout_editor_absoluteX="54dp"
        tools:srcCompat="@drawable/images" />
<!--
EditText:
-->
    <EditText
        android:id="@+id/txtMessaggio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ems="10"
        android:inputType="text"
        android:text="Scrivi un testo"
        tools:layout_editor_absoluteX="88dp"
        tools:layout_editor_absoluteY="333dp" />

</androidx.constraintlayout.widget.ConstraintLayout>